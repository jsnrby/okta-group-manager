# ─── Okta MCP Server (API Services app integration) ───────────────────────────
# This app integration authenticates the MCP server to call Okta APIs.
# Setup: Admin Console → Applications → Create App Integration → API Services
OKTA_ORG_URL=https://ic-demo.okta.com
OKTA_MCP_CLIENT_ID=

# RSA private key PEM — paste the full key including header/footer on one line
# with literal \n between lines, or use the multiline form below.
# Generate: openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
OKTA_PRIVATE_KEY=

# Key ID (kid) from the JWKS entry in your API Services app
OKTA_KEY_ID=

# Scopes granted to the API Services app (space-separated)
OKTA_SCOPES=okta.users.read okta.groups.read okta.groups.manage

# ─── Okta OIDC (Web/SPA app integration for Chainlit login) ───────────────────
# This app integration authenticates end users to the chatbot via their Okta account.
# Setup: Admin Console → Applications → Create App Integration → OIDC → Web Application
# Redirect URI: http://localhost:8000/auth/oauth/okta/callback
OAUTH_OKTA_CLIENT_ID=
OAUTH_OKTA_CLIENT_SECRET=
OAUTH_OKTA_DOMAIN=ic-demo.okta.com

# ─── Anthropic API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Chainlit ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
CHAINLIT_AUTH_SECRET=

# ─── MCP Server path ──────────────────────────────────────────────────────────
# Path to the cloned okta-mcp-server repo (relative to project root or absolute)
MCP_SERVER_PATH=./vendor/okta-mcp-server
